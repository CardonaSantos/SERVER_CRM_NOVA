  expedienteId Int
  expediente   ClienteExpediente @relation(fields: [expedienteId], references: [id])

  nombre   String
  telefono String
  relacion String

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt
}

// NUEVOS MODULOS - INVENTARIO Y GASTO TICKETS
// ============================================================
// EXTENSIÓN: TICKETS + INVENTARIO ESCALABLE
// Agregar al schema.prisma existente
// ============================================================
// ÍNDICE:
//   [A] Diff en modelos existentes (campos nuevos)
//   [B] TicketReasignacion
//   [C] GastoOperativo
//   [D] TicketGasto
//   [E] Bodega
//   [F] CategoriaProducto
//   [G] Producto
//   [H] StockProducto  ← fuente de verdad del inventario
//   [I] SerialProducto ← ONTs, routers (items serializables)
//   [J] MovimientoInventario
//   [K] Relaciones inversas a agregar en modelos existentes
//   [L] Enums nuevos
// ============================================================

// ============================================================
// [A] DIFF — Campos a agregar en modelos existentes
// ============================================================

// ── model TicketSoporte ──────────────────────────────────────
//   canalOrigen             CanalOrigen?          @default(ADMIN)
//   ultimaActividadEn       DateTime?
//   complejidad             NivelComplejidad?
//   minutosNoImputables     Int?                  @default(0)
//   contadorReasignaciones  Int                   @default(0)
//   costoTotal              Decimal?              @db.Decimal(12,2) @default(0)
//   // Evidencia de cierre — referencia al modelo Media existente
//   evidenciaCierreId       Int?
//   evidenciaCierre         Media?                @relation("EvidenciaCierreTicket", fields: [evidenciaCierreId], references: [id])
//   // Relaciones nuevas
//   reasignaciones          TicketReasignacion[]
//   gastos                  TicketGasto[]

// ── model TicketResumen ──────────────────────────────────────
//   slaBucket               SlaBucket?
//   // NOTA: age_hours no se persiste → calcular en query:
//   // EXTRACT(EPOCH FROM (NOW() - fecha_apertura)) / 3600

// ── model Media ─────────────────────────────────────────────
//   evidenciasCierreTicket  TicketSoporte[]       @relation("EvidenciaCierreTicket")
//   evidenciasGasto         GastoOperativo[]      @relation("EvidenciaGastoOperativo")

// ── model Empresa ────────────────────────────────────────────
//   gastosOperativos        GastoOperativo[]
//   bodegas                 Bodega[]
//   categoriaProductos      CategoriaProducto[]
//   productos               Producto[]
//   movimientosInventario   MovimientoInventario[]

// ── model Proveedor ──────────────────────────────────────────
//   movimientosInventario   MovimientoInventario[]

// HERRAMIENTAS
model PrestamoHerramienta {
  id Int @id @default(autoincrement())

  empresaId Int
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  // Herramienta exacta prestada
  serialProductoId Int
  serialProducto   SerialProducto @relation(fields: [serialProductoId], references: [id], onDelete: Restrict)

  // Bodega desde donde salió
  bodegaOrigenId Int?
  bodegaOrigen   Bodega? @relation("PrestamoBodegaOrigen", fields: [bodegaOrigenId], references: [id], onDelete: SetNull)

  // Bodega a donde debería regresar
  bodegaRetornoId Int?
  bodegaRetorno   Bodega? @relation("PrestamoBodegaRetorno", fields: [bodegaRetornoId], references: [id], onDelete: SetNull)

  // Técnico responsable
  tecnicoId Int
  tecnico   Usuario @relation("PrestamosHerramientaTecnico", fields: [tecnicoId], references: [id], onDelete: Cascade)

  // Quién entregó y quién recibió de vuelta
  entregadoPorId Int?
  entregadoPor   Usuario? @relation("PrestamosHerramientaEntregados", fields: [entregadoPorId], references: [id], onDelete: SetNull)

  recibidoPorId Int?
  recibidoPor   Usuario? @relation("PrestamosHerramientaRecibidos", fields: [recibidoPorId], references: [id], onDelete: SetNull)

  estado EstadoPrestamoHerramienta @default(PRESTADO)

  fechaPrestamo           DateTime  @default(now())
  fechaEsperadaDevolucion DateTime?
  fechaDevolucion         DateTime?

  observacionEntrega    String?
  observacionDevolucion String?
  motivoNoDevuelto      String?

  evidenciaEntregaMediaId Int?
  evidenciaEntregaMedia   Media? @relation("EvidenciaEntregaHerramienta", fields: [evidenciaEntregaMediaId], references: [id], onDelete: SetNull)

  evidenciaDevolucionMediaId Int?
  evidenciaDevolucionMedia   Media? @relation("EvidenciaDevolucionHerramienta", fields: [evidenciaDevolucionMediaId], references: [id], onDelete: SetNull)

  movimientoSalidaId Int?                  @unique
  movimientoSalida   MovimientoInventario? @relation("MovimientoSalidaPrestamo", fields: [movimientoSalidaId], references: [id], onDelete: SetNull)

  movimientoRetornoId Int?                  @unique
  movimientoRetorno   MovimientoInventario? @relation("MovimientoRetornoPrestamo", fields: [movimientoRetornoId], references: [id], onDelete: SetNull)

  ticketsUso TicketHerramientaUso[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([empresaId, estado])
  @@index([serialProductoId])
  @@index([tecnicoId])
  @@index([fechaPrestamo])
}

model TicketHerramientaUso {
  id Int @id @default(autoincrement())

  prestamoHerramientaId Int
  prestamoHerramienta   PrestamoHerramienta @relation(fields: [prestamoHerramientaId], references: [id], onDelete: Cascade)

  ticketId Int
  ticket   TicketSoporte @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  tecnicoId Int?
  tecnico   Usuario? @relation("TicketHerramientaUsoTecnico", fields: [tecnicoId], references: [id], onDelete: SetNull)

  usadoEn          DateTime @default(now())
  devueltoEnTicket Boolean  @default(false)

  nota String?

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@unique([prestamoHerramientaId, ticketId])
  @@index([ticketId])
  @@index([prestamoHerramientaId])
}

enum EstadoPrestamoHerramienta {
  PRESTADO // salió y aún no regresa
  DEVUELTO // regresó bien
  DEVUELTO_DANADO // regresó, pero dañado
  PERDIDO // no regresó
  CANCELADO // préstamo anulado
}

// ============================================================
// [B] HISTORIAL DE REASIGNACIONES
// ============================================================

model TicketReasignacion {
  id       Int           @id @default(autoincrement())
  ticketId Int
  ticket   TicketSoporte @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  tecnicoAnteriorId Int?
  tecnicoAnterior   Usuario? @relation("ReasignacionDe", fields: [tecnicoAnteriorId], references: [id], onDelete: SetNull)
  tecnicoNuevoId    Int
  tecnicoNuevo      Usuario  @relation("ReasignacionA", fields: [tecnicoNuevoId], references: [id], onDelete: Cascade)
  reasignadoPorId   Int?
  reasignadoPor     Usuario? @relation("QuienReasigno", fields: [reasignadoPorId], references: [id], onDelete: SetNull)

  motivo        String?
  reasignadoEn  DateTime @default(now())
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([ticketId])
  @@index([tecnicoNuevoId])
}

// ============================================================
// [C] GASTO OPERATIVO — pool central de gastos
//     Gastos libres (gasolina, viáticos) O generados automáticamente
//     desde inventario (MATERIAL). Siempre se distribuye via TicketGasto.
// ============================================================

model GastoOperativo {
  id        Int     @id @default(autoincrement())
  empresaId Int
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  registradoPorId Int?
  registradoPor   Usuario? @relation("GastosRegistrados", fields: [registradoPorId], references: [id], onDelete: SetNull)

  tipoGasto   TipoGasto
  subtipo     String?
  descripcion String?

  montoTotal    Decimal @default(0) @db.Decimal(12, 2)
  esRecuperable Boolean @default(false)

  evidenciaMediaId Int?
  evidenciaMedia   Media? @relation("EvidenciaGastoOperativo", fields: [evidenciaMediaId], references: [id])

  productoId Int?
  producto   Producto? @relation(fields: [productoId], references: [id], onDelete: SetNull)

  movimientoInventarioId Int?                  @unique
  movimientoInventario   MovimientoInventario? @relation(fields: [movimientoInventarioId], references: [id], onDelete: SetNull)

  estado        EstadoGasto @default(BORRADOR)
  aprobadoPorId Int?
  aprobadoPor   Usuario?    @relation("GastosAprobados", fields: [aprobadoPorId], references: [id], onDelete: SetNull)
  aprobadoEn    DateTime?

  fechaGasto    DateTime @default(now())
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  ticketAsignaciones TicketGasto[]

  clienteInstalacionId Int?
  clienteInstalacion   ClienteInstalacion? @relation(fields: [clienteInstalacionId], references: [id], onDelete: SetNull)

  clienteDesinstalacionId Int?
  clienteDesinstalacion   ClienteDesinstalacion? @relation(fields: [clienteDesinstalacionId], references: [id], onDelete: SetNull)

  @@index([clienteInstalacionId])
  @@index([clienteDesinstalacionId])
  @@index([empresaId, tipoGasto, fechaGasto])
  @@index([registradoPorId])
  @@index([productoId])
}

// ============================================================
// [D] TICKET GASTO — pivote de asignación (gasto → ticket)
//     Un GastoOperativo puede repartirse entre N tickets.
//     montoAsignado es lo que realmente suma al costoTotal del ticket.
// ============================================================

model TicketGasto {
  id       Int            @id @default(autoincrement())
  ticketId Int
  ticket   TicketSoporte  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  gastoId  Int
  gasto    GastoOperativo @relation(fields: [gastoId], references: [id], onDelete: Cascade)

  montoAsignado      Decimal  @default(0) @db.Decimal(12, 2)
  porcentajeAsignado Decimal? @db.Decimal(6, 2) // 25.00 = 25%

  tecnicoId     Int?
  tecnico       Usuario? @relation("GastosAsignadosTecnico", fields: [tecnicoId], references: [id], onDelete: SetNull)
  asignadoPorId Int?
  asignadoPor   Usuario? @relation("GastosAsignadosPor", fields: [asignadoPorId], references: [id], onDelete: SetNull)

  nota          String?
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@unique([ticketId, gastoId])
  @@index([ticketId])
  @@index([gastoId])
}

// ============================================================
// [E] BODEGA — ubicaciones de stock
//     Hoy: "Almacén Central". Mañana: vehículos, sucursales.
//     Agregar una bodega nueva nunca rompe nada.
// ============================================================

model Bodega {
  id        Int     @id @default(autoincrement())
  empresaId Int
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  nombre        String // "Almacén Central", "Vehículo Técnico #1"
  tipo          TipoBodega @default(ALMACEN)
  descripcion   String?
  responsableId Int? // usuario encargado de esta bodega
  responsable   Usuario?   @relation("BodegaResponsable", fields: [responsableId], references: [id], onDelete: SetNull)
  activo        Boolean    @default(true)

  stockProductos     StockProducto[]
  movimientosOrigen  MovimientoInventario[] @relation("MovimientoOrigen")
  movimientosDestino MovimientoInventario[] @relation("MovimientoDestino")
  seriales           SerialProducto[] // items serializables guardados aquí

  prestamosOrigen  PrestamoHerramienta[] @relation("PrestamoBodegaOrigen")
  prestamosRetorno PrestamoHerramienta[] @relation("PrestamoBodegaRetorno")

  equiposDesinstalacionRecibidos ClienteDesinstalacionEquipo[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@unique([empresaId, nombre])
  @@index([empresaId])
}

// ============================================================
// [F] CATEGORÍA DE PRODUCTO
// ============================================================

model CategoriaProducto {
  id        Int     @id @default(autoincrement())
  empresaId Int
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  nombre      String // "Equipos Ópticos", "Cable y Conectores", "Herramientas"
  descripcion String?
  activo      Boolean    @default(true)
  productos   Producto[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@unique([empresaId, nombre])
}

// ============================================================
// [G] PRODUCTO — catálogo maestro
//     stockTotal es denormalizado (suma de StockProducto).
//     La fuente de verdad siempre es StockProducto.
// ============================================================

model Producto {
  id        Int     @id @default(autoincrement())
  empresaId Int
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  categoriaId Int?
  categoria   CategoriaProducto? @relation(fields: [categoriaId], references: [id], onDelete: SetNull)

  nombre       String
  descripcion  String?
  sku          String?
  unidadMedida String? @default("unidad")

  costoPromedio Decimal  @default(0) @db.Decimal(12, 2)
  costoUltimo   Decimal? @db.Decimal(12, 2)

  stockTotal  Decimal @default(0) @db.Decimal(10, 2)
  stockMinimo Decimal @default(0) @db.Decimal(10, 2)

  esSeriable Boolean @default(false)
  esActivo   Boolean @default(false)

  activo      Boolean @default(true)
  isEliminado Boolean @default(false)

  stockPorBodega   StockProducto[]
  seriales         SerialProducto[]
  movimientos      MovimientoInventario[]
  gastosOperativos GastoOperativo[]

  instalacionesCliente    ClienteInstalacionEquipo[]
  desinstalacionesCliente ClienteDesinstalacionEquipo[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@unique([empresaId, sku])
  @@index([empresaId, categoriaId])
}

// ============================================================
// [H] STOCK POR BODEGA — la fuente de verdad del inventario
//     Una fila por cada combinación (producto, bodega).
//     Para saber cuánto hay de X en Y → buscar aquí.
//     Para saber cuánto hay de X en total → SUM o Producto.stockTotal
// ============================================================

model StockProducto {
  id         Int      @id @default(autoincrement())
  productoId Int
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  bodegaId   Int
  bodega     Bodega   @relation(fields: [bodegaId], references: [id], onDelete: Cascade)

  cantidad          Decimal @default(0) @db.Decimal(10, 2)
  // Cantidad reservada para movimientos pendientes (futuro)
  cantidadReservada Decimal @default(0) @db.Decimal(10, 2)
  // cantidadDisponible = cantidad - cantidadReservada (calculado en query)

  actualizadoEn DateTime @updatedAt

  @@unique([productoId, bodegaId])
  @@index([bodegaId])
  @@index([productoId])
}

// ============================================================
// [I] SERIAL DE PRODUCTO — tracking individual (ONTs, routers)
//     Solo aplica cuando Producto.esSeriable = true.
//     Permite saber exactamente qué ONT está en qué cliente.
// ============================================================

model SerialProducto {
  id         Int      @id @default(autoincrement())
  productoId Int
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  serial String // MAC address o número de serie del fabricante
  estado EstadoSerial @default(EN_STOCK)

  // Ubicación actual del equipo
  bodegaId Int? // null si ya está instalado en campo
  bodega   Bodega? @relation(fields: [bodegaId], references: [id], onDelete: SetNull)

  // Si está instalado
  clienteId           Int?
  cliente             ClienteInternet? @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  ticketInstalacionId Int? // ticket donde se realizó la instalación
  ticketInstalacion   TicketSoporte?   @relation(fields: [ticketInstalacionId], references: [id], onDelete: SetNull)

  instaladoEn DateTime?

  // Si está defectuoso / en reparación
  motivoBaja String?
  fechaBaja  DateTime?

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  movimientos          MovimientoInventario[]
  prestamosHerramienta PrestamoHerramienta[]

  instalacionesCliente    ClienteInstalacionEquipo[]
  desinstalacionesCliente ClienteDesinstalacionEquipo[]

  @@unique([serial])
  @@index([productoId, estado])
  @@index([clienteId])
}

model MovimientoInventario {
  id        Int     @id @default(autoincrement())
  empresaId Int
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  productoId Int
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  tipoMovimiento TipoMovimiento

  cantidad      Decimal @db.Decimal(10, 2)
  costoUnitario Decimal @db.Decimal(12, 2)
  costoTotal    Decimal @db.Decimal(14, 2) // cantidad × costoUnitario

  // Dónde entra/sale el stock
  bodegaOrigenId  Int?
  bodegaOrigen    Bodega? @relation("MovimientoOrigen", fields: [bodegaOrigenId], references: [id], onDelete: SetNull)
  bodegaDestinoId Int?
  bodegaDestino   Bodega? @relation("MovimientoDestino", fields: [bodegaDestinoId], references: [id], onDelete: SetNull)

  // Contexto del movimiento
  ticketId Int? // SALIDA ligada a un ticket de soporte
  ticket   TicketSoporte? @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  proveedorId Int? // ENTRADA de compra
  proveedor   Proveedor? @relation(fields: [proveedorId], references: [id], onDelete: SetNull)

  referencia String? // nro. factura de compra, orden de trabajo
  notas      String?

  realizadoPorId Int?
  realizadoPor   Usuario? @relation("MovimientosRealizados", fields: [realizadoPorId], references: [id], onDelete: SetNull)

  // Snapshot del stock total del producto al momento del movimiento (para auditoría)
  stockResultante Decimal? @db.Decimal(10, 2)

  // Si el item es seriable, qué serial específico se movió
  serialId       Int?
  serialProducto SerialProducto? @relation(fields: [serialId], references: [id], onDelete: SetNull)

  prestamoSalida  PrestamoHerramienta? @relation("MovimientoSalidaPrestamo")
  prestamoRetorno PrestamoHerramienta? @relation("MovimientoRetornoPrestamo")

  instalacionesCliente    ClienteInstalacionEquipo[]
  desinstalacionesCliente ClienteDesinstalacionEquipo[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  // Relación inversa: el GastoOperativo auto-generado por este movimiento (si aplica)
  // FK está en GastoOperativo.movimientoInventarioId
  gastoOperativo GastoOperativo?

  @@index([serialId])
  @@index([productoId, tipoMovimiento, creadoEn])
  @@index([empresaId, creadoEn])
  @@index([ticketId])
  @@index([bodegaOrigenId])
  @@index([bodegaDestinoId])
}


model ClienteInstalacionMedia {
  id            Int @id @default(autoincrement())
  instalacionId Int
  mediaId       Int

  tipo        TipoEvidenciaClienteOperacion @default(OTRO)
  descripcion String?
  orden       Int                           @default(0)

  creadoEn DateTime @default(now())

  instalacion ClienteInstalacion @relation(fields: [instalacionId], references: [id], onDelete: Cascade)
  media       Media              @relation(fields: [mediaId], references: [id], onDelete: Restrict)

  @@unique([instalacionId, mediaId])
  @@index([mediaId])
}

model ClienteInstalacionTecnico {
  id            Int  @id @default(autoincrement())
  instalacionId Int
  tecnicoId     Int?

  rol RolTecnicoOperacionCliente @default(APOYO)

  esResponsable Boolean @default(false)
  tiempoMinutos Int?
  observaciones String?

  tecnicoNombreSnapshot String?

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  instalacion ClienteInstalacion @relation(fields: [instalacionId], references: [id], onDelete: Cascade)
  tecnico     Usuario?           @relation("InstalacionTecnicoUsuario", fields: [tecnicoId], references: [id], onDelete: SetNull)

  @@index([instalacionId])
  @@index([tecnicoId])
}

model ClienteInstalacionEquipo {
  id            Int @id @default(autoincrement())
  instalacionId Int

  productoId             Int?
  serialProductoId       Int?
  movimientoInventarioId Int?

  descripcion String?
  cantidad    Decimal @default(1) @db.Decimal(10, 2)

  costoUnitario Decimal @default(0) @db.Decimal(12, 2)
  costoTotal    Decimal @default(0) @db.Decimal(12, 2)

  esPrincipal Boolean @default(false)

  serialSnapshot String?
  notas          String?

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  instalacion ClienteInstalacion @relation(fields: [instalacionId], references: [id], onDelete: Cascade)

  producto             Producto?             @relation(fields: [productoId], references: [id], onDelete: SetNull)
  serialProducto       SerialProducto?       @relation(fields: [serialProductoId], references: [id], onDelete: SetNull)
  movimientoInventario MovimientoInventario? @relation(fields: [movimientoInventarioId], references: [id], onDelete: SetNull)

  @@index([instalacionId])
  @@index([productoId])
  @@index([serialProductoId])
  @@index([movimientoInventarioId])
}

model ClienteInstalacion {
  id Int @id @default(autoincrement())

  empresaId Int
  clienteId Int

  servicioInternetId Int?
  ticketId           Int?

  asesorId        Int?
  creadoPorId     Int?
  completadoPorId Int?

  tipo   TipoInstalacionCliente   @default(NUEVA)
  estado EstadoInstalacionCliente @default(PROGRAMADA)

  fechaProgramada         DateTime?
  fechaInicio             DateTime?
  fechaFinalizacion       DateTime?
  fechaCancelacion        DateTime?
  fechaActivacionServicio DateTime?

  motivo        String?
  observaciones String?
  resultado     String?

  direccionInstalacion String?
  referenciaUbicacion  String?
  latitud              Float?
  longitud             Float?

  ssidRouter     String?
  contrasenaWifi String?

  costoInstalacion    Decimal @default(0) @db.Decimal(12, 2)
  costoMateriales     Decimal @default(0) @db.Decimal(12, 2)
  costoManoObra       Decimal @default(0) @db.Decimal(12, 2)
  costoOtros          Decimal @default(0) @db.Decimal(12, 2)
  montoCobradoCliente Decimal @default(0) @db.Decimal(12, 2)
  saldoPendiente      Decimal @default(0) @db.Decimal(12, 2)

  notasCostos String?

  esMigrada Boolean @default(false)
  metadata  Json?

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  empresa          Empresa           @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente          ClienteInternet   @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  servicioInternet ServicioInternet? @relation(fields: [servicioInternetId], references: [id], onDelete: SetNull)
  ticket           TicketSoporte?    @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  asesor        Usuario? @relation("InstalacionAsesor", fields: [asesorId], references: [id], onDelete: SetNull)
  creadoPor     Usuario? @relation("InstalacionCreadoPor", fields: [creadoPorId], references: [id], onDelete: SetNull)
  completadoPor Usuario? @relation("InstalacionCompletadoPor", fields: [completadoPorId], references: [id], onDelete: SetNull)

  tecnicos         ClienteInstalacionTecnico[]
  evidencias       ClienteInstalacionMedia[]
  equipos          ClienteInstalacionEquipo[]
  gastosOperativos GastoOperativo[]

  @@index([empresaId, estado])
  @@index([empresaId, clienteId])
  @@index([clienteId, fechaFinalizacion])
  @@index([servicioInternetId])
  @@index([ticketId])
  @@index([asesorId])
  @@index([creadoPorId])
  @@index([completadoPorId])
  @@index([estado, fechaProgramada])
}

// DESINSTALACION
model ClienteDesinstalacion {
  id Int @id @default(autoincrement())

  empresaId Int
  clienteId Int

  servicioInternetId Int?
  ticketId           Int?

  solicitadoPorId Int?
  ejecutadoPorId  Int?
  creadoPorId     Int?

  tipo   TipoDesinstalacionCliente    @default(COMPLETA)
  motivo MotivoDesinstalacionCliente?
  estado EstadoDesinstalacionCliente  @default(PROGRAMADA)

  fechaSolicitud    DateTime?
  fechaProgramada   DateTime?
  fechaInicio       DateTime?
  fechaFinalizacion DateTime?
  fechaCancelacion  DateTime?

  requiereRetiroEquipo Boolean @default(true)
  equipoRecuperado     Boolean @default(false)

  saldoClienteAlMomento Decimal @default(0) @db.Decimal(12, 2)
  costoDesinstalacion   Decimal @default(0) @db.Decimal(12, 2)
  costoTransporte       Decimal @default(0) @db.Decimal(12, 2)
  costoManoObra         Decimal @default(0) @db.Decimal(12, 2)
  costoOtros            Decimal @default(0) @db.Decimal(12, 2)

  direccionServicio   String?
  referenciaUbicacion String?
  latitud             Float?
  longitud            Float?

  firmadoPor  String?
  dpiFirmante String?
  conforme    Boolean?

  observaciones String?
  resultado     String?
  metadata      Json?

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  empresa          Empresa           @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente          ClienteInternet   @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  servicioInternet ServicioInternet? @relation(fields: [servicioInternetId], references: [id], onDelete: SetNull)
  ticket           TicketSoporte?    @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  solicitadoPor Usuario? @relation("DesinstalacionSolicitadoPor", fields: [solicitadoPorId], references: [id], onDelete: SetNull)
  ejecutadoPor  Usuario? @relation("DesinstalacionEjecutadoPor", fields: [ejecutadoPorId], references: [id], onDelete: SetNull)
  creadoPor     Usuario? @relation("DesinstalacionCreadoPor", fields: [creadoPorId], references: [id], onDelete: SetNull)

  tecnicos         ClienteDesinstalacionTecnico[]
  evidencias       ClienteDesinstalacionMedia[]
  equipos          ClienteDesinstalacionEquipo[]
  gastosOperativos GastoOperativo[]

  @@index([empresaId, estado])
  @@index([empresaId, clienteId])
  @@index([clienteId, fechaFinalizacion])
  @@index([servicioInternetId])
  @@index([ticketId])
  @@index([solicitadoPorId])
  @@index([ejecutadoPorId])
  @@index([creadoPorId])
  @@index([estado, fechaProgramada])
}

model ClienteDesinstalacionTecnico {
  id               Int  @id @default(autoincrement())
  desinstalacionId Int
  tecnicoId        Int?
  rol RolTecnicoOperacionCliente @default(APOYO)
  esResponsable Boolean @default(false)
  tiempoMinutos Int?
  observaciones String?
  tecnicoNombreSnapshot String?
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt
  desinstalacion ClienteDesinstalacion @relation(fields: [desinstalacionId], references: [id], onDelete: Cascade)
  tecnico        Usuario?              @relation("DesinstalacionTecnicoUsuario", fields: [tecnicoId], references: [id], onDelete: SetNull)

  @@index([desinstalacionId])
  @@index([tecnicoId])
}

model ClienteDesinstalacionMedia {
  id               Int @id @default(autoincrement())
  desinstalacionId Int
  mediaId          Int
  tipo        TipoEvidenciaClienteOperacion @default(OTRO)
  descripcion String?
  orden       Int                           @default(0)
  creadoEn DateTime @default(now())
  desinstalacion ClienteDesinstalacion @relation(fields: [desinstalacionId], references: [id], onDelete: Cascade)
  media          Media                 @relation(fields: [mediaId], references: [id], onDelete: Restrict)

  @@unique([desinstalacionId, mediaId])
  @@index([mediaId])
}

model ClienteDesinstalacionEquipo {
  id               Int @id @default(autoincrement())
  desinstalacionId Int
  productoId             Int?
  serialProductoId       Int?
  movimientoInventarioId Int?
  bodegaDestinoId        Int?
  descripcion String?
  cantidad    Decimal @default(1) @db.Decimal(10, 2)
  estadoRetiro EstadoEquipoRetirado @default(RECUPERADO_BUENO)
  costoRecuperacion Decimal @default(0) @db.Decimal(12, 2)
  serialSnapshot String?
  notas          String?
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  desinstalacion ClienteDesinstalacion @relation(fields: [desinstalacionId], references: [id], onDelete: Cascade)
  producto       Producto?       @relation(fields: [productoId], references: [id], onDelete: SetNull)
  serialProducto SerialProducto? @relation(fields: [serialProductoId], references: [id], onDelete: SetNull)
  movimientoInventario MovimientoInventario? @relation(fields: [movimientoInventarioId], references: [id], onDelete: SetNull)
  bodegaDestino        Bodega?               @relation(fields: [bodegaDestinoId], references: [id], onDelete: SetNull)

  @@index([desinstalacionId])
  @@index([productoId])
  @@index([serialProductoId])
  @@index([movimientoInventarioId])
  @@index([bodegaDestinoId])
}

model ClienteEstadoHistorial {
  id Int @id @default(autoincrement())

  empresaId Int
  clienteId Int

  tipoCambio TipoCambioEstadoCliente
  estadoAnterior EstadoCliente?
  estadoNuevo    EstadoCliente?
  isEliminadoAnterior Boolean?
  isEliminadoNuevo    Boolean?
  whatsappActivoAnterior Boolean?
  whatsappActivoNuevo    Boolean?
  motivo      String?
  descripcion String?
  cambiadoPorId Int?
  creadoEn DateTime @default(now())

  empresa Empresa         @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente ClienteInternet @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  cambiadoPor Usuario? @relation("ClienteEstadoCambiadoPor", fields: [cambiadoPorId], references: [id], onDelete: SetNull)

  @@index([clienteId, creadoEn])
  @@index([empresaId, tipoCambio])
  @@index([cambiadoPorId])
}

